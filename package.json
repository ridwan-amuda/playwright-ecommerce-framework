{
  "name": "playwright-ecommerce-framework",
  "version": "1.0.0",
  "description": "Playwright UI and API automation framework using JavaScript",
  "main": "index.js",
  "scripts": {
    "test:bdd": "cucumber-js",
    "report": "node reports/report.js",
    "test:report": "npm run test:bdd && npm run report",
    "test:headed": "cucumber-js --world-parameters '{\"headless\":false}'",
    "test:smoke": "cucumber-js --tags \"@smoke\"",
    "test:ui": "cucumber-js --tags \"@ui\"",
    "test:api": "cucumber-js --tags \"@api\"",
    "test:hybrid": "cucumber-js --tags \"@hybrid\"",
    "test:regression": "cucumber-js --tags \"@regression\"",
    "auth:save": "node scripts/saveAuthState.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "multiple-cucumber-html-reporter": "^3.10.0"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "dotenv": "^17.4.2"
  }
}
